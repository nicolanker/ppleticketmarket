# Copy to .env and adjust. All values have sensible dev defaults.

# --- Database ---
# SQLite for dev; swap for a postgresql:// URL in production.
DATABASE_URL=sqlite:///./market.db

# --- Admin console (/admin) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- Order constraints ---
MIN_QUANTITY=1
MAX_QUANTITY=5
MAX_PRICE_EUROS=10000

# Optional: restrict to university domains (comma-separated). Empty = any email.
# ALLOWED_EMAIL_DOMAINS=uva.nl,student.uva.nl

# --- Email delivery: console | smtp | resend ---
# "console" just logs; nothing is sent (default, zero config).
EMAIL_PROVIDER=resend

# RESEND (recommended) — sign up free at https://resend.com
#   1. Create an API key (Dashboard -> API Keys) and paste it below.
#   2. TESTING: leave EMAIL_FROM as onboarding@resend.dev. In test mode Resend
#      only delivers to the email you signed up with.
#   3. PRODUCTION: verify a domain (Dashboard -> Domains, add the DNS records),
#      then set EMAIL_FROM to something like "PPLE Market <market@yourdomain.com>"
#      to email arbitrary university addresses.
RESEND_API_KEY=
EMAIL_FROM=PPLE Ticket Market <onboarding@resend.dev>

# SMTP (only if EMAIL_PROVIDER=smtp) — e.g. Gmail/iCloud with an app password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
